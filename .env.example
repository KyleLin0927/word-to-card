# 必填：Google AI API Key（從 https://aistudio.google.com/app/apikey 取得）
GEMINI_API_KEY=your_gemini_api_key_here

# 選填：Gemini 模型（預設 gemini-2.0-flash）
# GEMINI_MODEL=gemini-2.0-flash

# 選填：Anki 牌組名稱（預設 Vocabulary::WordToCard）。
# 會決定 vocabulary/<slug>/ 與 word_history/<slug>.json（slug 由牌組名稱正規化，:: 階層化為 __）
# ANKI_DECK_NAME=Vocabulary::WordToCard

# 片語 Cloze 牌組（與單字分離；去重 phrase_history/<slug>.json、封存 vocabulary_phrases 依此 slug）
# ANKI_PHRASE_DECK_NAME=Vocabulary::Phrases

# 片語每次 Gemini 至多產出筆數（預設 1：只取最重要的一個搭配；設為 2～12 時仍須符合雅思／托福／學術取向）
# MAX_PHRASES_PER_RESPONSE=1

# 片語快捷鍵：⌘⌃D 截圖、⌃V 反白後觸發（仍以 Cmd+C 取得選取文字）
# HOTKEY_SCREENSHOT_PHRASE=<cmd>+<ctrl>+d
# HOTKEY_PHRASE_SELECTIONS=<ctrl>+v

# 選填：快捷鍵（預設 Cmd+Shift+W）
# HOTKEY=<cmd>+<shift>+w

# 選填：AnkiConnect 位址（預設 localhost:8765）
# ANKI_CONNECT_URL=http://localhost:8765

# 選填：本地單字 JSON「基底」目錄（預設 vocabulary；實際寫入為 基底/<牌組 slug>/）
# WORD_ARCHIVE_ENABLED=true
# WORD_ARCHIVE_DIR=vocabulary

# 選填：成功新增 Anki 卡片後，除通知中心外是否再播放短音效（外接螢幕／專注模式時橫幅可能不出現）
# NOTIFY_SUCCESS_SOUND=true
# NOTIFY_SUCCESS_SOUND_FILE=/System/Library/Sounds/Glass.aiff
